CLOUD_RU_API_KEY=
CLOUD_RU_BASE_URL=https://foundation-models.api.cloud.ru/v1
CLOUD_RU_MODEL=ai-sage/GigaChat3-10B-A1.8B

# MemPalace integration (optional)
MEMPALACE_MCP_URL=
MEMPALACE_COMMAND=python3 -m mempalace.mcp_server

# Ouroboros integration (optional)
OUROBOROS_DESKTOP_URL=http://127.0.0.1:8765
OUROBOROS_DESKTOP_FALLBACK=false
OUROBOROS_A2A_URL=
OUROBOROS_A2A_PASSWORD=
OUROBOROS_A2A_ENABLED=false

# Search providers (optional, at least one recommended)
TAVILY_API_KEY=
SERPER_API_KEY=
SEARXNG_URL=

# Puppeteer (optional)
PUPPETEER_EXECUTABLE_PATH=

# Whisper model for transcription
CLOUD_RU_WHISPER_MODEL=

# Telegram bot (optional)
BOT_TOKEN=
WEB_APP_URL=
SOCKS_PROXY=
